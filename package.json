{
  "name": "misc-mdn.dev",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "fmt": "prettier --write .",
    "lint": "eslint ./src/",
    "generate:cms": "npx --yes microcms-typescript schemas src/lib/utils/types/microcms.ts",
    "test": "tsc && prettier --check ./src/ && eslint ./src/ && vitest --run",
    "create-empty-mocks": "node scripts/create-empty-mocks.mjs",
    "clean": "npx --yes rimraf ./node_modules ./dist ./.sveltekit"
  },
  "devDependencies": {
    "@iconify/svelte": "^5.0.0",
    "@markuplint/svelte-parser": "^4.18.3",
    "@sveltejs/adapter-auto": "^3.3.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.64.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/dom-view-transitions": "^1.0.6",
    "@types/eslint": "^8.56.12",
    "@types/node": "^20.19.42",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.6.0",
    "eslint-plugin-svelte": "^2.46.1",
    "eslint-plugin-unused-imports": "^3.2.0",
    "prettier": "^3.8.4",
    "sass": "^1.100.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-meta-tags": "^5.0.0",
    "sveltekit-view-transition": "^0.5.3",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/m-plus-1": "^5.2.10",
    "@fontsource/noto-color-emoji": "^5.2.12",
    "@iconify-json/mdi": "^1.2.3",
    "@nanostores/persistent": "^0.10.2",
    "bits-ui": "^2.0.0",
    "cheerio": "^1.2.0",
    "highlight.js": "^11.11.1",
    "just-extend": "^6.2.0",
    "microcms-js-sdk": "^3.4.0",
    "nanostores": "^0.10.3",
    "the-new-css-reset": "^1.11.3"
  },
  "engines": {
    "node": "20.x"
  }
}
